# Database — Vercel Postgres (or compatible)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (email magic links) — must verify domain in Resend dashboard
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# QStash (Phase 5 — schedule + webhooks)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Encryption key for stored credentials — openssl rand -hex 32
ENCRYPTION_KEY=

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
